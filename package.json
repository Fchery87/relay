{
  "name": "relay",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*", "convex"],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter @relay/web build",
    "convex:dev": "bunx convex dev",
    "daemon:dev": "bun --cwd apps/daemon run dev",
    "web:dev": "bun --cwd apps/web run dev"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "convex": "^1.42.1",
    "typescript": "^5.9.3"
  }
}
