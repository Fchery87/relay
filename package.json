{
  "name": "relay",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*", "packages/providers/*", "convex"],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test && bun run --cwd convex test:convex",
    "build": "bun run --cwd apps/web build",
    "bundle:check": "bun run scripts/check-bundle-budget.ts",
    "daemon:build:native": "bun build --compile apps/daemon/src/cli.ts --outfile dist/relay",
    "convex:dev": "bunx convex dev",
    "daemon:connect": "bun --cwd apps/daemon run connect",
    "daemon:dev": "bun --cwd apps/daemon run dev",
    "web:dev": "bun --cwd apps/web run dev",
    "release:build": "bun run scripts/build-release.ts",
    "release:smoke": "bun run scripts/smoke-daemon.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "^1.3.14",
    "convex": "^1.42.1",
    "convex-test": "^0.0.54",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
