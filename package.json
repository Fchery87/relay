{
  "name": "relay",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*", "packages/providers/*", "convex"],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test && cd convex && bun run test:convex",
    "build": "cd apps/web && bun run build",
    "bundle:check": "bun run scripts/check-bundle-budget.ts",
    "security:gate": "bun run scripts/security-gate.ts",
    "codex:schema:check": "bun run scripts/check-codex-app-server-schema.ts",
    "codex:harness:smoke": "RELAY_E2E_CODEX=1 RELAY_CODEX_ENABLED=1 bun run scripts/smoke-codex-harness.ts",
    "conformance:matrix": "bun run scripts/run-conformance-matrix.ts",
    "crash:matrix": "bun run scripts/run-crash-matrix.ts --profile=pr",
    "test:e2e:harness": "bun run scripts/production-acceptance.ts",
    "eval:harness": "bun run scripts/eval-harness.ts",
    "load:client": "bun run scripts/load-client-runtime.ts",
    "daemon:build:native": "bun build --compile apps/daemon/src/cli.ts --outfile dist/relay",
    "convex:dev": "bunx convex dev",
    "convex:verify": "bun run scripts/verify-self-hosted-convex.ts",
    "convex:backup": "scripts/backup-self-hosted-convex.sh",
    "convex:restore": "scripts/restore-self-hosted-convex.sh",
    "daemon:connect": "cd apps/daemon && bun run connect",
    "daemon:dev": "cd apps/daemon && bun run dev",
    "web:dev": "cd apps/web && bun run dev",
    "release:build": "bun run scripts/build-release.ts",
    "release:smoke": "bun run scripts/smoke-daemon.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "^1.3.14",
    "convex": "^1.42.1",
    "convex-test": "^0.0.54",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
